# syntax=docker/dockerfile:1.7

# Image used by both `dev` and `build` compose profiles.
# Source code is bind-mounted at runtime, so we install nothing here —
# `pnpm install` runs in the container the first time you start it.
FROM node:22-alpine
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@10.21.0 --activate
ENV NEXT_TELEMETRY_DISABLED=1 \
    PNPM_HOME=/root/.local/share/pnpm \
    PATH=/root/.local/share/pnpm:$PATH
EXPOSE 3000
